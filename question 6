let a = parseInt(prompt("Enter a:"));
let b = parseInt(prompt("Enter b:"));
let c = parseInt(prompt("Enter c:"));

let score = (3 * a) + b - (2 * c);

if (score < 0) {
    score = 0;
}

let totalAttempts = a + b + c;

if (totalAttempts > 50) {
    score = score - 10;
}

if (score >= 60) {
    alert(score + ", PASS");
} else {
    alert(score + ", FAIL");
}
